            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "Full HTML5 tag coverage with typed attribute validation via Pydantic",
    "Component-based composable element tree using Python's call syntax",
    "Automatic HTML escaping with explicit SafeString opt-out for trusted content",
    "SVG and MathML element support alongside HTML",
    "HTMX integration via HTMXAttributes TypedDict mixin",
    "Alpine.js integration with AlpineJSData helper for reactive state",
    "Tailwind CSS class merging with tw_merge() for conflict resolution",
    "Chart.js configuration helpers via ChartJSConfig Pydantic models"
  ],
  "publicApiSurface": [
    "render(*elements, stringify=True) -> str",
    "BaseWebElement",
    "BaseAttribute",
    "WebElementType",
    "mark_safe(string) -> SafeString",
    "aether.tags.html.* (all HTML5 elements)",
    "aether.tags.svg.* (SVG elements: Svg, Circle, Rect, Path, G, etc.)",
    "aether.tags.mathml.* (MathML elements)",
    "aether.plugins.htmx.HTMXAttributes",
    "aether.plugins.alpinejs.AlpineJSData",
    "aether.plugins.alpinejs.alpine_js_data_merge()",
    "aether.plugins.alpinejs.AlpineHookForm",
    "aether.plugins.alpinejs.Statement",
    "aether.plugins.tailwindcss.tw_merge(*tw_classes) -> str",
    "aether.plugins.chartjs.ChartJSConfig",
    "aether.plugins.chartjs.ChartJSDataset",
    "aether.plugins.chartjs.build_chart_config_from_attributes()"
  ]
}
