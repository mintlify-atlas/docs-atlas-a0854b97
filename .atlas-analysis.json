{
  "projectType": "sdk-library",
  "projectName": "Aether",
  "projectDescription": "A Python DSL for building HTML user interfaces using component-based Python objects, with built-in support for SVG, MathML, HTMX, Alpine.js, Tailwind CSS, and Chart.js.",
  "theme": "luma",
  "primaryColor": "#4F6EF7",
  "lightColor": "#EEF1FE",
  "darkColor": "#1A2266",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
